# ============================================================
# ConversionOS — LOKALNI development (.env.local)
# Kopiraj ovaj fajl:  cp .env.local.example .env.local
# Vrednosti ispod odgovaraju `supabase start` lokalnom steku.
# Potvrdi ih komandom:  supabase status
# ============================================================

# Supabase — lokalni API (http://127.0.0.1:54321)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# Lokalni anon key (fiksiran za local Supabase, bezbedan za commit u primeru)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A9WOaZRIzlhRcBCS7UXpXI86cOiQKPmYgT6NPC
# Lokalni service_role key — SERVER ONLY, nikad u client bundle
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImV4cCI6MTk4MzgxMjk5Nn0.EGIM96RAZx35lJzdJsyH-qQwv8Hdcpe-5DnQkCA2pC

# Tracking / security — nasumični string za hash IP adresa (lokalno, bilo šta dugačko)
IP_SALT=local-dev-ip-salt-change-me-in-production

# ============================================================
# Bitrix24 — OPCIONO dok ne povežeš webhook
# ============================================================
# BITRIX_WEBHOOK_URL=https://YOUR_PORTAL.bitrix24.com/rest/USER_ID/TOKEN
# BITRIX_WEBHOOK_SECRET=local-dev-bitrix-secret

# ============================================================
# NAPOMENA za produkciju:
# U `.env.production` (ili Vercel dashboard) stavi PRAVE cloud vrednosti
# sa Supabase → Project Settings → API. Ovaj fajl je samo za lokalni dev.
# ============================================================
