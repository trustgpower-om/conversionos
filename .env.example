# ============================
# Supabase — public keys (RLS)
# ============================
# URL and anon key from Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_anon_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# ============================
# Supabase — server-only key
# ============================
# service_role key — NEVER in client code, server only
SUPABASE_SERVICE_ROLE_KEY=sb_service_role_XXXXXXXXXXXXXXXXXXXXXXXX

# ============================
# Bitrix24
# ============================
# Incoming webhook URL for crm.lead.add
BITRIX_WEBHOOK_URL=https://YOUR_PORTAL.bitrix24.com/rest/USER_ID/TOKEN

# Shared secret for Outgoing Webhook (Bitrix → our API)
BITRIX_WEBHOOK_SECRET=CHANGE_ME_TO_LONG_RANDOM_STRING

# ============================
# Tracking / security
# ============================
# Salt for hashing IP addresses (SHA-256)
IP_SALT=CHANGE_ME_TO_ANOTHER_LONG_RANDOM_STRING
